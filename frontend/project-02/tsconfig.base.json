{
  "compileOnSave": false,
  "compilerOptions": {
    "rootDir": ".",
    "sourceMap": true,
    "declaration": false,
    "moduleResolution": "node",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "es2015",
    "module": "esnext",
    "lib": ["es2020", "dom"],
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "products": ["libs/products/src/index.ts"],
      "@services": ["libs/services/src/index.ts"],
      "persons-table": ["libs/persons-table/src/index.ts"],
      "@stats": ["libs/stats/src/index.ts"],
      "@chart-line": ["libs/charts/line-chart/src/index.ts"],
      "@pie-chart": ["libs/charts/pie-chart/src/index.ts"],
      "@bar-chart": ["libs/charts/bar-chart/src/index.ts"],
      "@scatter-chart": ["libs/charts/scatter-chart/src/index.ts"],
      "@candlestick-chart": ["libs/charts/candlestick-chart/src/index.ts"],
      "@radar-chart": ["libs/charts/radar-chart/src/index.ts"],
      "@boxplot-chart": ["libs/charts/boxplot-chart/src/index.ts"],
      "@heatmap-chart": ["libs/charts/heatmap-chart/src/index.ts"],
      "@graph-chart": ["libs/charts/graph-chart/src/index.ts"],
      "@graph-geo-chart": ["libs/charts/graph-geo-chart/src/index.ts"],
      "@graph-lines-chart": ["libs/charts/graph-lines-chart/src/index.ts"],
      "@tree-chart": ["libs/charts/tree-chart/src/index.ts"],
      "@treemap-chart": ["libs/charts/treemap-chart/src/index.ts"],
      "@sunburst-chart": ["libs/charts/sunburst-chart/src/index.ts"],
      "@parallel-chart": ["libs/charts/parallel-chart/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "tmp"]
}
